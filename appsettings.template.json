{
  // ---------------------------------------------------------------------------
  // DevDashboard configuration template.
  //
  // Copy this file to:   %LOCALAPPDATA%\DevDashboard\appsettings.json
  // and fill in your own values. On first run the app seeds that copy for you,
  // so you can also just run it once and then edit the generated file.
  //
  // Comments and trailing commas are allowed (the .NET JSON config provider
  // skips them), so you can keep these notes in your real config if you like.
  // ---------------------------------------------------------------------------
  "AzureDevOps": {
    // Your Azure DevOps organization URL.
    "OrganizationUrl": "https://dev.azure.com/your-org",

    // The ADO project whose board the bug / defect metrics are read from.
    "BoardsProject": "Your.Project",

    // Projects searched when discovering the repositories listed below.
    "CandidateProjects": [
      "Your.Project",
      "Another.Project"
    ],

    // Email of the signed-in (az login) user. Used to surface *your* review
    // activity separately. Leave "" to disable the personal breakdown.
    "CurrentUserEmail": "you@example.com",

    // Repositories to track, each mapped to its local working-copy path. The
    // local path is the working directory used when launching a background
    // agent ('c') for one of that repo's PRs. Use "" for a tracked repo you
    // have no local checkout of (the launch then refuses for that repo).
    "Repositories": {
      "Your.Repo.One": "C:\\path\\to\\Your.Repo.One",
      "Your.Repo.Two": ""
    }
  },

  // Prompt handed to `claude --bg` when launching an agent on a PR.
  // {URL} is replaced with the selected PR's web URL.
  "PrAgent": {
    "PromptTemplate": "Focus on this PR {URL}. Fetch azure infos and wait for next input"
  },

  // Display names of the required reviewers whose first vote the
  // review-turnaround metric measures.
  "RequiredReviewers": [
    "Reviewer One",
    "Reviewer Two"
  ],

  // Repositories (by name) to exclude from the throughput / defect statistics.
  "ExcludedFromStatsRepos": [
  ],

  "Metrics": {
    // Business hours within which a PR should receive its first required review.
    "SlaBusinessHours": 24,
    // Trailing window (days) for the headline review-turnaround percentage.
    "TrailingWindowDays": 90,
    // How far back to backfill on the first (cold-start) sync.
    "BackfillDays": 180,
    // Start date for goal tracking (ISO 8601).
    "GoalStartDate": "2026-01-01"
  }
}
